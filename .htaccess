<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]
    RewriteRule ^(\.env|artisan|composer\.(json|lock)|package\.json)$ - [F,L]

    # If the request is for an existing file/dir in public/, serve it directly
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^ - [L]

    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^ - [L]

    # Route everything through public/index.php
    RewriteRule ^ /public/index.php [L]
</IfModule>
